# Volvo DNS TAPIR - Environment Configuration
# Copy this file to .env and fill in your actual values before running start.sh

# The absolute path to your Kong Enterprise license.json file downloaded from Jelle
KONG_LICENSE_PATH="/Users/YOUR-USERNAME/Downloads/license.json"

# Your OpenRouter API key started with sk-or-v1-... from Bluetext platform
OPENROUTER_API_KEY="sk-or-v1-****************************************"
